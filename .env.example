# Copy to .env and fill in real values. .env is git-ignored.

DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SITE_BASE_URL=http://localhost:8000

# --- Telegram (real tokens from @BotFather) ---
# Staff alert bot + the chat ids that should receive low-stock alerts.
TELEGRAM_STAFF_BOT_TOKEN=
TELEGRAM_STAFF_CHAT_IDS=
# Customer receipt bot (@Cloude_Customer_Bot)
TELEGRAM_CUSTOMER_BOT_TOKEN=

# --- Payment gateway ---
# Provider id: "mock" (dev), or a real provider once implemented.
PAYMENT_GATEWAY=mock
PAYMENT_API_KEY=
PAYMENT_API_SECRET=
PAYMENT_WEBHOOK_SECRET=
